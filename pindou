<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MARD拼豆像素画工具（官方221色版）</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet">
    <style>
        .pixel-image {
            image-rendering: pixelated !important;
            image-rendering: crisp-edges !important;
            image-rendering: -moz-crisp-edges !important;
            transform: translateZ(0);
        }
        #zoomContainer {
            overflow: auto;
            max-width: 100%;
            max-height: 700px;
            position: relative;
            background: #f3f4f6;
            padding: 10px;
        }
        #zoomWrapper {
            transform-origin: 0 0;
            transition: transform 0.1s;
            cursor: grab;
            display: inline-block;
        }
        #zoomWrapper:active {
            cursor: grabbing;
        }
        :fullscreen #zoomContainer {
            max-height: 100vh !important;
            background: #fff !important;
            padding: 20px;
        }
        /* 新增：优化色号文字样式，避免遮挡 */
        .color-code-text {
            font-size: 5px !important; /* 缩小字号 */
            font-weight: normal !important; /* 取消粗体 */
            letter-spacing: -0.5px; /* 缩小字间距 */
            text-shadow: 0.5px 0.5px 1px rgba(0,0,0,0.2); /* 轻微阴影提升可读性 */
        }
    </style>
</head>
<body class="bg-gray-50">
<header class="bg-white shadow sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center gap-2">
        <i class="fa fa-paint-brush text-indigo-600 text-2xl"></i>
        <h1 class="text-xl font-bold">MARD拼豆像素画工具（官方221色版）</h1>
    </div>
</header>

<main class="max-w-6xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="space-y-6">
            <div class="bg-white rounded-xl p-6 shadow">
                <h2 class="text-lg font-semibold mb-3">上传图片</h2>
                <div id="dropArea" class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center cursor-pointer hover:border-indigo-500 transition-colors">
                    <input type="file" id="fileInput" accept="image/png,image/jpg,image/jpeg,image/webp" class="hidden">
                    <i class="fa fa-image text-3xl text-gray-400 mb-2"></i>
                    <p class="text-sm text-gray-500">点击或拖拽图片（支持PNG/JPG/WEBP）</p>
                </div>
            </div>

            <div class="bg-white rounded-xl p-6 shadow">
                <h2 class="text-lg font-semibold mb-3">参数设置</h2>
                <div class="space-y-3">
                    <div>
                        <label class="text-sm block mb-1">像素精度 <span id="pixelSizeText" class="text-indigo-600">64</span></label>
                        <input type="range" id="pixelSize" min="16" max="128" value="64" step="8" class="w-full h-2 bg-gray-200 rounded accent-indigo-600">
                    </div>
                    <div>
                        <label class="text-sm block mb-1">颜色匹配精度 <span id="colorToleranceText" class="text-indigo-600">30</span></label>
                        <input type="range" id="colorTolerance" min="0" max="100" value="30" class="w-full h-2 bg-gray-200 rounded accent-indigo-600">
                        <div class="text-xs text-gray-500 mt-1">数值越小，匹配越精准（0=严格匹配）</div>
                    </div>
                    <div class="flex gap-2 pt-1 flex-wrap">
                        <button id="processBtn" class="flex-1 bg-indigo-600 text-white py-2 rounded disabled:opacity-50 disabled:cursor-not-allowed transition-opacity" disabled><i class="fa fa-magic mr-1"></i> 生成</button>
                        <button id="exportBtn" class="flex-1 bg-emerald-600 text-white py-2 rounded disabled:opacity-50 disabled:cursor-not-allowed transition-opacity" disabled><i class="fa fa-download mr-1"></i> 导出</button>
                        <button id="fullscreenBtn" class="flex-1 bg-orange-500 text-white py-2 rounded transition-bg hover:bg-orange-600"><i class="fa fa-expand mr-1"></i> 全屏</button>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl p-6 shadow max-h-[400px] overflow-y-auto">
                <h2 class="text-lg font-semibold mb-3">MARD颜色统计</h2>
                <div id="colorStats" class="space-y-2"></div>
            </div>
        </div>

        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white rounded-xl p-6 shadow">
                <h2 class="text-lg font-semibold mb-3">原始图片</h2>
                <div class="flex justify-center items-center bg-gray-50 rounded h-[260px]">
                    <img id="originalImage" class="max-h-full max-w-full object-contain hidden" alt="原始图片">
                    <p id="noOriginalImage" class="text-gray-400">未上传图片</p>
                </div>
            </div>

            <div class="bg-white rounded-xl p-6 shadow">
                <h2 class="text-lg font-semibold mb-3">MARD拼豆图纸（官方色号）</h2>
                <div id="zoomContainer">
                    <div id="zoomWrapper">
                        <div id="pixelCanvasContainer" class="hidden relative">
                            <canvas id="pixelCanvas" class="pixel-image" alt="拼豆图纸"></canvas>
                            <div id="numberOverlay" class="absolute top-0 left-0 w-full h-full pointer-events-none"></div>
                        </div>
                    </div>
                </div>
                <p id="noPixelImage" class="text-gray-400 text-center py-12">点击生成后显示官方色号图纸</p>
            </div>
        </div>
    </div>
</main>

