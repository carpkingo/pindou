        {code: 'H22', hex: '#CACAD4'}, {code: 'H23', hex: '#9A9D94'},

        {code: 'M1', hex: '#BCC6B8'}, {code: 'M2', hex: '#8AA386'}, {code: 'M3', hex: '#697D80'},
