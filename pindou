        {code: 'M7', hex: '#B4A497'}, {code: 'M8', hex: '#B38281'}, {code: 'M9', hex: '#A58767'},
        {code: 'M10', hex: '#C5B2BC'}, {code: 'M11', hex: '#9F7594'}, {code: 'M12', hex: '#644749'},
        {code: 'M13', hex: '#D19066'}, {code: 'M14', hex: '#C77362'}, {code: 'M15', hex: '#757D78'}
    ].map(color => {
        // 预转换十六进制到RGB，提升匹配效率
        const rgb = hexToRgb(color.hex);
        return { ...color, r: rgb.r, g: rgb.g, b: rgb.b };
    });

    // 全局元素获取
    const dropArea = document.getElementById('dropArea');
    const fileInput = document.getElementById('fileInput');
    const originalImage = document.getElementById('originalImage');
    const pixelSize = document.getElementById('pixelSize');
    const pixelSizeText = document.getElementById('pixelSizeText');
    const colorTolerance = document.getElementById('colorTolerance');
    const colorToleranceText = document.getElementById('colorToleranceText');
    const processBtn = document.getElementById('processBtn');
    const exportBtn = document.getElementById('exportBtn');
    const fullscreenBtn = document.getElementById('fullscreenBtn');
    const pixelCanvas = document.getElementById('pixelCanvas');
    const pixelCanvasContainer = document.getElementById('pixelCanvasContainer');
    const noOriginalImage = document.getElementById('noOriginalImage');
    const noPixelImage = document.getElementById('noPixelImage');
    const colorStats = document.getElementById('colorStats');
    const numberOverlay = document.getElementById('numberOverlay');
    const zoomWrapper = document.getElementById('zoomWrapper');
    const zoomContainer = document.getElementById('zoomContainer');
    const ctx = pixelCanvas.getContext('2d');

    // 全局变量
    let originalImageFile = null;
    let pixelData = [];
    let colorMap = [];
    let imgWidth = 0;
    let imgHeight = 0;
    let scale = 1;
    let drag = false, startX = 0, startY = 0;
    const displayScale = 10; // 画布显示缩放比例

    // 初始化滑块文字
    pixelSizeText.textContent = pixelSize.value;
    colorToleranceText.textContent = colorTolerance.value;

    // 滑块事件监听
    pixelSize.addEventListener('input', () => {
        pixelSizeText.textContent = pixelSize.value;
    });
    colorTolerance.addEventListener('input', () => {
        colorToleranceText.textContent = colorTolerance.value;
    });

    // 全屏/退出全屏
    fullscreenBtn.addEventListener('click', () => {
        if (!document.fullscreenElement && !document.webkitFullscreenElement) {
            (zoomContainer.requestFullscreen || zoomContainer.webkitRequestFullscreen).call(zoomContainer);
            fullscreenBtn.innerHTML = '<i class="fa fa-compress mr-1"></i> 退出';
        } else {
            (document.exitFullscreen || document.webkitExitFullscreen).call(document);
            fullscreenBtn.innerHTML = '<i class="fa fa-expand mr-1"></i> 全屏';
        }
    });

    // 全屏状态变化监听
    document.addEventListener('fullscreenchange', () => {
        if (!document.fullscreenElement) {
            fullscreenBtn.innerHTML = '<i class="fa fa-expand mr-1"></i> 全屏';
        }
    });

    // 图片上传：点击/拖拽
    dropArea.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', handleFileUpload);
    dropArea.addEventListener('dragover', e => {
        e.preventDefault();
        dropArea.classList.add('border-indigo-500', 'bg-indigo-50');
    });
    dropArea.addEventListener('dragleave', () => {
        dropArea.classList.remove('border-indigo-500', 'bg-indigo-50');
    });
    dropArea.addEventListener('drop', e => {
        e.preventDefault();
        dropArea.classList.remove('border-indigo-500', 'bg-indigo-50');
        fileInput.files = e.dataTransfer.files;
        handleFileUpload();
    });

    // 处理文件上传
    function handleFileUpload() {
        const file = fileInput.files[0];
        if (!file) return;

        // 校验图片格式
        const validTypes = ['image/png', 'image/jpg', 'image/jpeg', 'image/webp'];
        if (!validTypes.includes(file.type)) {
            alert('请上传PNG/JPG/WEBP格式的图片！');
            return;
        }

        originalImageFile = file;
        const reader = new FileReader();
        reader.onload = e => {
            originalImage.src = '';
            originalImage.onload = () => {
                noOriginalImage.classList.add('hidden');
                originalImage.classList.remove('hidden');
                processBtn.disabled = false;
                exportBtn.disabled = true;
            };
            originalImage.src = e.target.result;
        };
        reader.readAsDataURL(file);
    }

    // 生成MARD官方色号拼豆图纸
    processBtn.addEventListener('click', async () => {
        if (!originalImageFile) return;
        processBtn.disabled = true;
        processBtn.innerHTML = '<i class="fa fa-spinner fa-spin mr-1"></i> 匹配MARD色号中';

        try {
            const img = new Image();
            img.crossOrigin = 'anonymous';
            img.src = URL.createObjectURL(originalImageFile);
            const loadPromise = new Promise((resolve, reject) => {
                img.onload = resolve;
                img.onerror = reject;
                setTimeout(() => reject(new Error('图片加载超时')), 5000);
            });
            await loadPromise;

            // 计算画布宽高（按比例适配像素精度）
            const baseSize = parseInt(pixelSize.value);
            const ratio = img.width / img.height || 1;
            imgWidth = baseSize;
            imgHeight = Math.round(baseSize / ratio);
            imgWidth = Math.max(8, Math.min(200, imgWidth));
            imgHeight = Math.max(8, Math.min(200, imgHeight));

            // 初始化画布
            pixelCanvas.width = imgWidth;
            pixelCanvas.height = imgHeight;
            ctx.clearRect(0, 0, imgWidth, imgHeight);
            ctx.imageSmoothingEnabled = false;
            ctx.drawImage(img, 0, 0, imgWidth, imgHeight);

            // 核心：匹配MARD官方色号
            matchMardColors();
            renderPixelImage();
            renderColorNumbers(); // 渲染色号文字（已优化）
            updateColorStats();

            // 显示画布
            pixelCanvas.style.width = `${imgWidth * displayScale}px`;
            pixelCanvas.style.height = `${imgHeight * displayScale}px`;
            pixelCanvasContainer.classList.remove('hidden');
            noPixelImage.classList.add('hidden');
            exportBtn.disabled = false;

        } catch (err) {
            console.error('生成失败：', err);
            alert(`生成图纸失败：${err.message}，请更换图片重试！`);
        } finally {
            processBtn.disabled = false;
            processBtn.innerHTML = '<i class="fa fa-magic mr-1"></i> 生成';
        }
    });

    // ======================
    // 核心算法：图片颜色 → 就近匹配MARD官方色号
    // 基于RGB色差计算，匹配最接近的MARD官方颜色
    // ======================
    function matchMardColors() {
        const imageData = ctx.getImageData(0, 0, imgWidth, imgHeight);
        const data = imageData.data;
        const tol = 100 - parseInt(colorTolerance.value); // 反向适配滑块（值越小越精准）
        const colorDict = new Map();
        pixelData = [];

        for (let y = 0; y < imgHeight; y++) {
            const row = [];
            for (let x = 0; x < imgWidth; x++) {
                const i = (y * imgWidth + x) * 4;
                let r = data[i] || 0, g = data[i+1] || 0, b = data[i+2] || 0, a = data[i+3] || 0;
                if (a < 128) { row.push(null); continue; }

                // 计算当前像素与所有MARD颜色的色差，取最接近的
                let closestColor = null;
                let minDistance = Infinity;
                MARD_COLORS.forEach(mardColor => {
                    // 计算RGB色差（欧几里得距离，加权提升视觉一致性）
                    const rDiff = (r - mardColor.r) * 0.3;
                    const gDiff = (g - mardColor.g) * 0.59;
                    const bDiff = (b - mardColor.b) * 0.11;
                    const distance = Math.sqrt(rDiff**2 + gDiff**2 + bDiff**2);

                    // 匹配最接近的颜色
                    if (distance < minDistance && distance <= tol) {
                        minDistance = distance;
                        closestColor = mardColor;
                    }
                });

                // 兜底：如果无匹配（极特殊情况），取白色H2
                if (!closestColor) closestColor = MARD_COLORS.find(c => c.code === 'H2');
                const key = closestColor.code;

                // 统计颜色数量
                if (!colorDict.has(key)) {
                    colorDict.set(key, {
                        ...closestColor,
                        count: 0
                    });
                }
                const color = colorDict.get(key);
                color.count++;
                row.push(color);
            }
            pixelData.push(row);
        }

        // 按色号排序，方便查看
        colorMap = Array.from(colorDict.values()).sort((a, b) => {
            if (a.code[0] !== b.code[0]) {
                return a.code[0].localeCompare(b.code[0]);
            }
            return parseInt(a.code.slice(1)) - parseInt(b.code.slice(1));
        });
    }

    // 渲染MARD官方颜色像素画
    function renderPixelImage() {
        ctx.clearRect(0, 0, imgWidth, imgHeight);
        ctx.imageSmoothingEnabled = false;
        for (let y = 0; y < imgHeight; y++) {
            for (let x = 0; x < imgWidth; x++) {
                const c = pixelData[y][x];
                if (!c) continue;
                ctx.fillStyle = c.hex;
                ctx.fillRect(x, y, 1, 1);
            }
        }
    }

    // 渲染MARD官方色号数字覆盖层（核心修改：优化文字样式）
    function renderColorNumbers() {
        if (!colorMap.length) return;
        numberOverlay.innerHTML = '';
        numberOverlay.style.width = pixelCanvas.style.width;
        numberOverlay.style.height = pixelCanvas.style.height;

        for (let y = 0; y < imgHeight; y++) {
            for (let x = 0; x < imgWidth; x++) {
                const c = pixelData[y][x];
                if (!c) continue;
                // 根据背景亮度自动切换文字颜色（黑/白）
                const brightness = (c.r * 0.299 + c.g * 0.587 + c.b * 0.114);
                const textColor = brightness > 150 ? '#000000' : '#ffffff';

                const elem = document.createElement('div');
                elem.innerText = c.code;
                // 关键修改：缩小字号、取消粗体、微调位置、添加轻微阴影提升可读性
                elem.style.cssText = `
                    position: absolute;
                    width: ${displayScale}px; 
                    height: ${displayScale}px;
                    display: flex; 
                    align-items: center; 
                    justify-content: center;
                    color: ${textColor}; 
                    font-size: 4px; /* 原7px → 缩小至4px */
                    font-weight: normal; /* 原bold → 取消粗体 */
                    transform: scale(0.85); /* 轻微缩放进一步减小视觉占比 */
                    left: ${x * displayScale}px;
                    top: ${y * displayScale}px;
                    text-shadow: 0.3px 0.3px 0.5px rgba(0,0,0,0.15); /* 轻微阴影提升可读性，不遮挡 */
                `;
                numberOverlay.appendChild(elem);
            }
        }
    }

    // 更新左侧MARD颜色统计（官方色号+数量）
    function updateColorStats() {
        colorStats.innerHTML = '';
        if (!colorMap.length) {
            colorStats.innerHTML = '<p class="text-gray-400 text-center py-2">无颜色数据</p>';
            return;
        }

        let total = 0;
        colorMap.forEach(c => {
            total += c.count;
            const div = document.createElement('div');
            div.className = 'flex justify-between items-center p-2 bg-gray-50 rounded hover:bg-gray-100 transition-bg';
            div.innerHTML = `
                <div class="flex items-center gap-2">
                    <div class="w-4 h-4 rounded border border-gray-200" style="background:${c.hex}"></div>
                    <span>MARD 色号：<span class="font-medium">${c.code}</span></span>
                </div>
                <span class="text-gray-600">${c.count} 粒</span>
            `;
            colorStats.appendChild(div);
        });

        // 总计
        const totalEl = document.createElement('div');
        totalEl.className = 'mt-2 p-2 bg-indigo-100 rounded text-center font-medium text-indigo-700';
        totalEl.textContent = `🧩 总计：${total} 粒拼豆（共${colorMap.length}种MARD官方色）`;
        colorStats.appendChild(totalEl);
    }

    // 导出高清MARD图纸（自动适配列数+官方色号）
    exportBtn.addEventListener('click', () => {
        if (!colorMap.length || !imgWidth || !imgHeight) {
            alert('无图纸数据，无法导出！');
            return;
        }

        const cellSize = 60;    // 单个拼豆格子大小（高清）
        const padding = 50;     // 画布内边距
        const blockSize = 20;   // 颜色统计色块大小
        const fontSize = 14;    // 颜色统计文字大小（适配字母+数字色号）
        const lineHeight = 30;  // 颜色统计行高
        const singleColorItemWidth = blockSize + 90 + 20; // 适配MARD色号（如A26、M15）

        // 计算可用宽度+动态列数，修复极窄图计算异常
        const canvasTotalWidth = Math.max(400, imgWidth * cellSize + padding * 2);
        const canvasAvailableWidth = canvasTotalWidth - padding * 2;
        let colCount = Math.floor(canvasAvailableWidth / singleColorItemWidth);
        // 列数上下限+兜底
        colCount = Math.max(4, Math.min(40, colCount));
        colCount = Math.min(colCount, colorMap.length || 1);

        const totalCount = colorMap.length;
        const rowCount = Math.ceil(totalCount / colCount);
        const statHeight = 20 + rowCount * lineHeight + 40;
        const canvasTotalHeight = imgHeight * cellSize + statHeight + padding * 1.5;

        // 创建高清导出画布
        const cv = document.createElement('canvas');
        const cx = cv.getContext('2d');
        cv.width = canvasTotalWidth;
        cv.height = canvasTotalHeight;
        cx.fillStyle = '#ffffff';
        cx.fillRect(0, 0, cv.width, cv.height);

        // 绘制MARD官方颜色拼豆格子
        cx.translate(padding, padding);
        cx.imageSmoothingEnabled = false;
        for (let y = 0; y < imgHeight; y++) {
            for (let x = 0; x < imgWidth; x++) {
                const c = pixelData[y][x];
                if (!c) continue;
                cx.fillStyle = c.hex;
                cx.fillRect(x * cellSize, y * cellSize, cellSize, cellSize);
                // 绘制格子边框，提升清晰度
                cx.strokeStyle = '#f0f0f0';
                cx.lineWidth = 0.8;
                cx.strokeRect(x * cellSize, y * cellSize, cellSize, cellSize);
            }
        }

        // 绘制MARD官方色号（A1/B2等）- 同步优化导出的文字样式
        cx.textAlign = 'center';
        cx.textBaseline = 'middle';
        cx.font = `normal ${cellSize * 0.18}px Arial`; // 原bold → normal，字号比例缩小
        for (let y = 0; y < imgHeight; y++) {
            for (let x = 0; x < imgWidth; x++) {
                const c = pixelData[y][x];
                if (!c) continue;
                const bright = c.r * 0.299 + c.g * 0.587 + c.b * 0.114;
                cx.fillStyle = bright > 160 ? '#000000' : '#ffffff';
                // 轻微描边提升可读性，不遮挡图像
                cx.strokeStyle = 'rgba(0,0,0,0.1)';
                cx.lineWidth = 0.5;
                cx.strokeText(c.code, x * cellSize + cellSize/2, y * cellSize + cellSize/2);
                cx.fillText(c.code, x * cellSize + cellSize/2, y * cellSize + cellSize/2);
            }
        }

        // 绘制颜色统计区域（MARD色号+数量）
        cx.resetTransform();
        const baseY = imgHeight * cellSize + padding + 20;
        const colWidth = canvasAvailableWidth / colCount;

        cx.font = `${fontSize}px Arial`;
        cx.textBaseline = 'middle';
        cx.textAlign = 'left';
        cx.fillStyle = '#333333';

        // 绘制每个MARD颜色统计项
        colorMap.forEach((c, i) => {
            const col = i % colCount;
            const row = Math.floor(i / colCount);
            const x = padding + col * colWidth;
            const y = baseY + row * lineHeight;

            // 绘制官方颜色色块
            cx.fillStyle = c.hex;
            cx.fillRect(x, y - blockSize/2, blockSize, blockSize);
            cx.strokeStyle = '#e0e0e0';
            cx.strokeRect(x, y - blockSize/2, blockSize, blockSize);

            // 绘制MARD色号+数量
            cx.fillStyle = '#333333';
            cx.fillText(`${c.code} (${c.count}粒)`, x + blockSize + 8, y);
        });

        // 绘制总计文字
        const total = colorMap.reduce((s, c) => s + c.count, 0);
        cx.font = 'bold 20px Arial';
        cx.fillStyle = '#4f46e5';
        cx.textAlign = 'center';
        cx.fillText(`MARD官方拼豆图纸 | 总计：${total} 粒（${colorMap.length}种官方色）`, cv.width / 2, baseY + rowCount * lineHeight + 25);

        // 下载高清图片
        try {
            const a = document.createElement('a');
            a.download = `MARD官方拼豆图纸_${new Date().getTime()}.png`;
            a.href = cv.toDataURL('image/png', 1.0); // 1.0最高画质
            a.click();
        } catch (err) {
            console.error('导出失败：', err);
            alert('导出图片失败，请尝试刷新页面重试！');
        }
    });

    // 画布缩放（滚轮）
    zoomContainer.addEventListener('wheel', e => {
        e.preventDefault();
        scale += e.deltaY > 0 ? -0.1 : 0.1;
        scale = Math.max(0.2, Math.min(6, scale));
        zoomWrapper.style.transform = `scale(${scale})`;
    });

    // 画布拖拽
    zoomWrapper.addEventListener('mousedown', e => {
        drag = true;
        startX = e.clientX - zoomWrapper.offsetLeft;
        startY = e.clientY - zoomWrapper.offsetTop;
        zoomWrapper.style.cursor = 'grabbing';
    });
    window.addEventListener('mousemove', e => {
        if (!drag) return;
        e.preventDefault();
        const x = e.clientX - startX;
        const y = e.clientY - startY;
        zoomWrapper.style.transform = `scale(${scale}) translate(${x}px, ${y}px)`;
    });
    window.addEventListener('mouseup', () => {
        drag = false;
        zoomWrapper.style.cursor = 'grab';
    });
    window.addEventListener('mouseleave', () => {
        drag = false;
        zoomWrapper.style.cursor = 'grab';
    });

    // 工具函数：十六进制转RGB
    function hexToRgb(hex) {
        const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
        return result ? {
            r: parseInt(result[1], 16),
            g: parseInt(result[2], 16),
            b: parseInt(result[3], 16)
        } : { r: 255, g: 255, b: 255 };
    }

    // 初始化缩放
    zoomWrapper.style.transform = 'scale(1)';
</script>
